# Database connection string
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# GitHub token for accessing repositories and API
GITHUB_TOKEN="ghp_your_github_token_here"

# Better Auth
BETTER_AUTH_SECRET="replace_with_random_secret"
BETTER_AUTH_URL="http://localhost:3000"

# Cron security
CRON_SECRET="replace_with_long_random_secret"
CRON_SCHEDULE="0 2 * * *"

# Optional: AI query suggestions (Phase 2)
# Keep disabled to preserve pure Phase 1 behavior.
AI_QUERY_SUGGESTIONS_ENABLED="false"
AI_QUERY_PROVIDER="gemini"
AI_QUERY_MODEL="gemini-2.5-flash-lite"
GOOGLE_GENERATIVE_AI_API_KEY=""
AI_QUERY_MAX_CALLS_PER_DAY="2"
AI_QUERY_MIN_HOURS_BETWEEN_CALLS="12"
AI_QUERY_MAX_SUGGESTIONS_PER_CALL="10"
